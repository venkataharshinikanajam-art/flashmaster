flowchart LR
    Client[Client Browser<br/>React 19 Frontend]

    subgraph View["VIEW — Routing Layer"]
        Routes["routes/auth.js<br/>routes/materials.js<br/>routes/flashcards.js<br/>routes/plans.js<br/>routes/admin.js<br/>..."]
    end

    subgraph Controller["CONTROLLER"]
        Handlers["Route handlers<br/>+ middleware<br/>+ services/"]
    end

    subgraph Model["MODEL — Mongoose Schemas"]
        Models["User.js<br/>StudyMaterial.js<br/>Flashcard.js<br/>StudyPlan.js<br/>Progress.js"]
    end

    DB[(MongoDB)]

    Client -- "HTTP request + JWT" --> Routes
    Routes -- "forwards to" --> Handlers
    Handlers -- "validates, orchestrates" --> Models
    Models -- "Mongoose driver" --> DB
    DB --> Models
    Models --> Handlers
    Handlers --> Routes
    Routes -- "JSON response" --> Client

