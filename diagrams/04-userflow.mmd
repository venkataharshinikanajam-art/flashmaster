flowchart TD
    Start([Open FLASHMASTER]) --> Role{Role?}

    Role -- Student --> S1[Sign up / Log in]
    S1 --> S2[Dashboard]
    S2 --> S3[Upload Material<br/>PDF or text]
    S3 --> S4[Auto-generated<br/>Flashcards]
    S4 --> S5[Filter by<br/>Subject / Topic]
    S5 --> S6[Study Mode<br/>reveal answers]
    S6 --> S7[Tag Difficulty<br/>Easy / Med / Hard]
    S7 --> S8[Create Study Plan<br/>with exam date]
    S8 --> S9[View Progress<br/>and Analytics]
    S9 --> SEnd([Logout])

    Role -- Admin --> A1[Log in as admin]
    A1 --> A2[Admin Dashboard]
    A2 --> A3[Users Tab<br/>view all users]
    A2 --> A4[Materials Tab<br/>view / delete uploads]
    A2 --> A5[Reports Tab<br/>platform stats]
    A3 --> AEnd([Logout])
    A4 --> AEnd
    A5 --> AEnd

    classDef student fill:#E0F2FE,stroke:#0284C7,color:#0C4A6E
    classDef admin fill:#FEE2E2,stroke:#DC2626,color:#7F1D1D
    class S1,S2,S3,S4,S5,S6,S7,S8,S9 student
    class A1,A2,A3,A4,A5 admin
