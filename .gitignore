# Dependencies
node_modules/
**/node_modules/

# Environment variables (secrets!)
.env
.env.local
.env.*.local
**/.env

# Build outputs
dist/
build/
**/dist/
**/build/

# Uploaded files (user-generated, not code)
server/uploads/
uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo

# Runtime / cache
.cache/
.parcel-cache/
.eslintcache

# Coverage reports
coverage/
*.lcov

# Temporary files
tmp/
temp/
*.tmp

# Python leftovers (just in case)
__pycache__/
*.pyc

# Do NOT ignore these
!.gitkeep
!.env.example
