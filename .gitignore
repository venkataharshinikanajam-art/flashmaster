# Dependencies
node_modules/
**/node_modules/

# Environment variables (secrets!)
.env
.env.local
.env.*.local
**/.env

# Build outputs
dist/
build/
**/dist/
**/build/

# Uploaded files (user-generated, not code)
backend/uploads/
uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code workspace metadata
.claude/

# Runtime / cache
.cache/
.parcel-cache/
.eslintcache

# Coverage reports
coverage/
*.lcov

# Temporary files
tmp/
temp/
*.tmp

# Word / Office lock files
~$*

# Do NOT ignore these
!.gitkeep
!.env.example
