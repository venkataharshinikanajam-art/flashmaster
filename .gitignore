.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo

# Runtime / cache
.cache/
.parcel-cache/
.eslintcache

# Coverage reports
coverage/
*.lcov

# Temporary files
tmp/
temp/
*.tmp

# Python leftovers (just in case)
