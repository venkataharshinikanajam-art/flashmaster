# Environment variables (secrets!)
.env
.env.local
.env.*.local
**/.env

# Build outputs
dist/
build/
**/dist/
**/build/

# Uploaded files (user-generated, not code)
server/uploads/
uploads/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

