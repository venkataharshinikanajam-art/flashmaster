# FLASHMASTER environment variables — TEMPLATE
#
# HOW TO USE:
# 1. Copy this file to a new file named `.env` (no extension prefix).
#    In bash:    cp .env.example .env
# 2. Fill in the real values in `.env`.
# 3. NEVER commit `.env` — it's in .gitignore for your safety.
# 4. When you add a new variable in code, also add it here (with a placeholder)
#    so future-you or teammates know it exists.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# The TCP port the Express backend listens on.
PORT=5000

# Environment name. Use "development" locally, "production" in deployment.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# MongoDB connection string. Default is your local MongoDB Community Edition.
# Format: mongodb://<host>:<port>/<database-name>
MONGODB_URI=mongodb://localhost:27017/flashmaster

# -----------------------------------------------------------------------------
# Authentication (Phase 4)
# -----------------------------------------------------------------------------
# Secret key used to sign JWT tokens. MUST be long and random in real deployments.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string

# How long a JWT token stays valid. e.g., 1h, 7d, 30d.
JWT_EXPIRES_IN=7d

# How many rounds bcrypt should use to hash passwords.
# Higher = slower to crack but also slower to log in. 10–12 is standard.
BCRYPT_SALT_ROUNDS=10

# -----------------------------------------------------------------------------
# Frontend (Phase 8+)
# -----------------------------------------------------------------------------
# URL where the Vite dev server runs. Used for CORS config on the backend.
CLIENT_ORIGIN=http://localhost:5173
